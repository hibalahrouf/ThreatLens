# ─── Database ───
POSTGRES_USER=masvs_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=masvs_copilot
DATABASE_URL=postgresql://masvs_user:change_me@postgres:5432/masvs_copilot

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── MobSF ───
MOBSF_URL=http://mobsf:8000
MOBSF_API_KEY=your_mobsf_api_key_here

# ─── MinIO ───
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=masvs-uploads
MINIO_USE_SSL=false

# ─── JWT ───
JWT_SECRET=change-me-to-a-strong-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── LLM ───
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_URL=http://localhost:11434
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# ─── App ───
APP_NAME=MASVS Audit Copilot
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
